---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  icon: string; // tabler icon name (no prefix)
}
const { title, icon } = Astro.props;
---

<section class="widget">
  <header class="widget-head">
    <Icon name={`tabler:${icon}`} class="wic" />
    <span>{title}</span>
  </header>
  <div class="widget-body">
    <slot />
  </div>
</section>

<style>
  .widget {
    border: 1px solid var(--color-border-mid);
    background: var(--color-bg-surface);
  }
  .widget + :global(.widget),
  .widget {
    margin-bottom: 12px;
  }
  .widget-head {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 9px;
    background: var(--color-bg-dark);
  }
  .wic {
    width: 13px;
    height: 13px;
    color: var(--color-rust);
    flex-shrink: 0;
  }
  .widget-head span {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-cream);
  }
  .widget-body {
    padding: 10px 9px;
  }
</style>
