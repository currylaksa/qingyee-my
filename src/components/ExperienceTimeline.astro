---
import { Icon } from 'astro-icon/components';
import { experience } from '../data/content';
---

<section class="experience" data-reveal>
  <h2 class="section-label">
    <Icon name="tabler:briefcase" class="sic" />
    Experience
  </h2>
  <div class="timeline">
    {experience.map((row) => (
      <div class="row">
        <span class="year">{row.year}</span>
        <div class="detail">
          <h3 class="role">{row.role}</h3>
          <p class="org">{row.org}</p>
          <p class="desc">{row.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .experience {
    padding: 18px 24px;
  }
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-primary);
  }
  .sic {
    width: 22px;
    height: 22px;
    color: var(--color-rust);
  }
  .row {
    display: flex;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .row:last-child { border-bottom: none; }
  .year {
    flex-shrink: 0;
    min-width: 44px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 10px;
    color: var(--color-rust);
    padding-top: 2px;
  }
  .role {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .org {
    margin: 2px 0 6px;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }
  .desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    line-height: 1.6;
    color: var(--color-text-body);
  }
</style>
