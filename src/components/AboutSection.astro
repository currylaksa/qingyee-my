---
import { Icon } from 'astro-icon/components';
import { about, personalInfo } from '../data/content';
import { getAssetPresence } from '../lib/assetPresence.server';

const { hasHeadshot } = getAssetPresence();
---

<section id="about" class="section about" data-reveal>
  <h2 class="section-label">
    <Icon name="tabler:user" class="sic" />
    About
  </h2>

  <div class="grid">
    <div class="bio">
      {about.bio.map((p) => <p>{p}</p>)}
    </div>

    <aside class="side">
      {hasHeadshot ? (
        <img class="shot photo" src="/headshot.jpg" alt={personalInfo.fullName} width="120" height="120" />
      ) : (
        <div class="shot initials" aria-label={personalInfo.fullName}>{personalInfo.initials}</div>
      )}
      <dl class="details">
        {about.details.map((d) => (
          <div class="drow">
            <dt>{d.label}</dt>
            <dd>{d.value}</dd>
          </div>
        ))}
      </dl>
    </aside>
  </div>
</section>

<style>
  .section {
    padding: 28px 24px;
    border-top: 3px solid var(--color-border-heavy);
  }
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-primary);
  }
  .sic { width: 24px; height: 24px; color: var(--color-rust); }

  .grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 28px;
    align-items: start;
  }
  .bio p {
    margin-bottom: 12px;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 13px;
    line-height: 1.8;
    color: var(--color-text-body);
    max-width: 600px;
  }

  .side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .shot {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 3px solid var(--color-border-heavy);
  }
  .shot.photo { object-fit: cover; }
  .shot.initials {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-rust);
    color: var(--color-text-cream);
    font-family: var(--font-display);
    font-size: 40px;
  }
  .details { width: 100%; }
  .drow { padding: 5px 0; border-bottom: 1px solid var(--color-border-light); }
  .drow dt {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-rust);
  }
  .drow dd {
    margin-top: 2px;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 11px;
    line-height: 1.5;
    color: var(--color-text-body);
  }

  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; }
    .section-label { font-size: 22px; }
  }
</style>
