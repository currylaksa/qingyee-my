---
import { personalInfo } from '../data/content';
---

<footer class="footer">
  <span class="copy">© 2026 {personalInfo.fullName} — qingyee.my</span>
  <span class="links">
    <a href={`mailto:${personalInfo.email}`}>Email</a>
    <a href={personalInfo.linkedin} target="_blank" rel="noopener">LinkedIn</a>
    <a href={personalInfo.github} target="_blank" rel="noopener">GitHub</a>
  </span>
</footer>

<style>
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    background: var(--color-bg-dark);
    border-top: 4px solid var(--color-rust);
  }
  .copy {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-cream);
  }
  .links {
    display: flex;
    gap: 14px;
  }
  .links a {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-rust-light);
    text-decoration: underline;
  }
  .links a:hover { color: var(--color-text-cream-dim); }
  @media (max-width: 600px) {
    .footer { flex-direction: column; text-align: center; }
  }
</style>
