---
import { Icon } from 'astro-icon/components';
import StatRow from './StatRow.astro';
import { wilderfarer, personalInfo, runningLog } from '../data/content';
---

<section id="wilderfarer" class="section">
  <h2 class="section-label">
    <Icon name="tabler:mountain" class="sic" />
    Wilderfarer
  </h2>

  <div class="grid">
    <div class="lead">
      <p class="narrative">{wilderfarer.narrative}</p>
      <ul class="identity">
        {personalInfo.identity.map((i) => <li>{i}</li>)}
      </ul>
    </div>

    <div class="panel">
      <h3 class="ptitle">Running Log</h3>
      {runningLog.map((s) => <StatRow label={s.label} value={s.value} />)}
    </div>

    <div class="panel">
      <h3 class="ptitle">Hiking Log</h3>
      <p class="todo">TODO: add recent trails / summits.</p>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 28px 24px;
    border-top: 3px solid var(--color-border-heavy);
  }
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-primary);
  }
  .sic { width: 24px; height: 24px; color: var(--color-rust); }

  .grid {
    display: grid;
    grid-template-columns: 1fr 200px 200px;
    gap: 24px;
    align-items: start;
  }
  .narrative {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 13px;
    line-height: 1.8;
    color: var(--color-text-body);
    max-width: 540px;
  }
  .identity {
    display: flex;
    gap: 14px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .identity li {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-rust);
  }
  .panel {
    padding: 12px;
    border: 1px solid var(--color-border-mid);
    background: var(--color-bg-surface);
  }
  .ptitle {
    margin-bottom: 8px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .todo {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--color-rust);
  }

  @media (max-width: 800px) {
    .grid { grid-template-columns: 1fr; }
    .section-label { font-size: 22px; }
  }
</style>
