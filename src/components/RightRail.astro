---
import { Icon } from 'astro-icon/components';
import Widget from './Widget.astro';
import StatRow from './StatRow.astro';
import { certs, runningLog, personalInfo } from '../data/content';
---

<div class="rail">
  <Widget title="Credentials" icon="certificate">
    <ul class="certs">
      {certs.map((c) => (
        <li>
          <Icon name={`tabler:${c.icon}`} class="cic" />
          <div>
            <p class="cname">{c.name}</p>
            <p class="corg">{c.org}</p>
          </div>
        </li>
      ))}
    </ul>
  </Widget>

  <Widget title="Running Log" icon="run">
    {runningLog.map((s) => <StatRow label={s.label} value={s.value} />)}
  </Widget>

  <Widget title="Wilderfarer" icon="mountain">
    <blockquote class="quote">
      Not all those who wander are lost — some are just between deployments.
    </blockquote>
    <ul class="identity">
      {personalInfo.identity.map((i) => <li>{i}</li>)}
    </ul>
    <p class="status">JB → Singapore</p>
  </Widget>
</div>

<style>
  .rail {
    padding: 12px 10px;
  }

  /* Credentials */
  .certs li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 0;
  }
  .certs li + li {
    border-top: 1px solid var(--color-border-light);
  }
  .cic {
    width: 16px;
    height: 16px;
    color: var(--color-rust);
    flex-shrink: 0;
  }
  .cname {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.5px;
    color: var(--color-text-primary);
  }
  .corg {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 9px;
    color: var(--color-text-muted);
  }

  /* Wilderfarer */
  .quote {
    margin-bottom: 8px;
    padding: 6px 8px;
    background: var(--color-bg-page);
    border-left: 4px solid var(--color-rust);
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 9px;
    line-height: 1.6;
    color: var(--color-text-body);
  }
  .identity li {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    line-height: 1.7;
    color: var(--color-text-body);
  }
  .status {
    margin-top: 6px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--color-rust);
  }
</style>
