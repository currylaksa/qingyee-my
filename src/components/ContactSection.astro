---
import { Icon } from 'astro-icon/components';
import { personalInfo } from '../data/content';
import { getAssetPresence } from '../lib/assetPresence.server';

const { hasFormKey } = getAssetPresence();
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section id="contact" class="section">
  <h2 class="section-label">
    <Icon name="tabler:mail" class="sic" />
    Contact
  </h2>

  <div class="grid">
    <div class="form-col">
      {hasFormKey ? (
        <>
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value={accessKey} />
            <input type="hidden" name="subject" value="New message from qingyee.my" />
            {/* honeypot */}
            <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

            <label>
              <span>Name</span>
              <input type="text" name="name" placeholder="Your name" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" placeholder="you@example.com" required />
            </label>
            <label>
              <span>Message</span>
              <textarea name="message" rows="5" placeholder="Your message" required></textarea>
            </label>
            <button type="submit">Send Message</button>
          </form>
          <div id="contact-success" class="success" hidden>
            <strong>Thanks — message sent.</strong>
            <p>I'll reply soon.</p>
          </div>
        </>
      ) : (
        <p class="notice">
          The contact form isn't live yet. Reach me directly at{' '}
          <a href={`mailto:${personalInfo.email}`}>{personalInfo.email}</a>.
        </p>
      )}

      <p class="fallback">
        Prefer email? <a href={`mailto:${personalInfo.email}`}>{personalInfo.email}</a>
      </p>
    </div>

    <aside class="channels">
      <a href={`mailto:${personalInfo.email}`}><Icon name="tabler:mail" /> Email</a>
      <a href={personalInfo.linkedin} target="_blank" rel="noopener"><Icon name="tabler:brand-linkedin" /> LinkedIn</a>
      <a href={personalInfo.whatsapp} target="_blank" rel="noopener"><Icon name="tabler:brand-whatsapp" /> {personalInfo.whatsappLabel}</a>
    </aside>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.hidden = true;
          success.hidden = false;
          return;
        }
        throw new Error('bad response');
      } catch {
        if (btn) { btn.disabled = false; btn.textContent = 'Send Message'; }
        alert('Sorry — something went wrong. Please email qingyee0219@gmail.com instead.');
      }
    });
  }
</script>

<style>
  .section {
    padding: 28px 24px 36px;
    border-top: 3px solid var(--color-border-heavy);
  }
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-primary);
  }
  .sic { width: 24px; height: 24px; color: var(--color-rust); }

  .grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 28px;
    align-items: start;
  }

  form { display: flex; flex-direction: column; gap: 12px; max-width: 480px; }
  label { display: flex; flex-direction: column; gap: 4px; }
  label span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  input[type='text'],
  input[type='email'],
  textarea {
    padding: 9px 10px;
    background: var(--color-bg-surface);
    border: 2px solid var(--color-border-heavy);
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-body);
  }
  input:focus, textarea:focus { outline: 2px solid var(--color-rust); outline-offset: -2px; }
  textarea { resize: vertical; }
  .hp { position: absolute; left: -9999px; }

  button {
    align-self: flex-start;
    padding: 9px 18px;
    background: var(--color-rust);
    color: var(--color-text-cream-dim);
    border: 2px solid var(--color-rust);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
  }
  button:hover { background: var(--color-rust-dark); border-color: var(--color-rust-dark); }
  button:disabled { opacity: 0.6; cursor: default; }

  .success {
    padding: 16px;
    border: 2px solid var(--color-rust);
    background: var(--color-bg-page);
    max-width: 480px;
  }
  .success strong {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--color-rust);
  }
  .success p { margin-top: 4px; font-family: var(--font-body); font-size: 12px; }

  .notice {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-text-body);
    max-width: 480px;
  }
  .notice a, .fallback a { color: var(--color-rust); text-decoration: underline; }
  .fallback {
    margin-top: 14px;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .channels { display: flex; flex-direction: column; gap: 12px; }
  .channels a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-body);
  }
  .channels a:hover { color: var(--color-rust); }
  .channels :global(svg) { width: 16px; height: 16px; color: var(--color-rust); flex-shrink: 0; }

  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; }
    .section-label { font-size: 22px; }
  }
</style>
