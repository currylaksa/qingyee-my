---
import { personalInfo } from '../data/content';
import StarBadge from './StarBadge.astro';
---

<header class="header" id="home">
  <div class="stripe" aria-hidden="true"></div>
  <div class="header-inner">
    <div class="left">
      <p class="eyebrow">{personalInfo.eyebrow}</p>
      <h1 class="name">{personalInfo.fullName}</h1>
      <p class="tagline">{personalInfo.tagline}</p>
    </div>
    <div class="right">
      <StarBadge />
    </div>
  </div>
</header>

<style>
  .header {
    position: relative;
    background: var(--color-bg-surface);
    border-bottom: 6px solid var(--color-rust);
  }
  .stripe {
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      #c0392b 0px,
      #c0392b 20px,
      #e8d5b8 20px,
      #e8d5b8 22px
    );
  }
  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 22px 24px;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--color-rust);
  }
  .name {
    font-size: 48px;
    color: var(--color-text-primary);
    margin: 4px 0 6px;
  }
  .tagline {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  @media (max-width: 600px) {
    .name { font-size: 32px; }
    .header-inner { padding: 18px 18px; }
    .tagline { letter-spacing: 2px; }
  }
</style>
