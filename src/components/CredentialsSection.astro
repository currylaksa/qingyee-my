---
import { Icon } from 'astro-icon/components';
import { certs } from '../data/content';
---

<section id="credentials" class="section">
  <h2 class="section-label">
    <Icon name="tabler:certificate" class="sic" />
    Credentials
  </h2>

  <div class="grid">
    {certs.map((c) => (
      <article class="cert">
        <Icon name={`tabler:${c.icon}`} class="cic" />
        <div>
          <p class="name">{c.name}</p>
          <p class="org">{c.org}</p>
          <p class="date">
            {c.date ?? <span class="todo">Issued — TODO</span>}
          </p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .section {
    padding: 28px 24px;
    border-top: 3px solid var(--color-border-heavy);
  }
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-primary);
  }
  .sic { width: 24px; height: 24px; color: var(--color-rust); }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .cert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    border: 2px solid var(--color-border-heavy);
    background: var(--color-bg-surface);
  }
  .cic { width: 26px; height: 26px; color: var(--color-rust); flex-shrink: 0; }
  .name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--color-text-primary);
  }
  .org {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    color: var(--color-text-muted);
  }
  .date {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-text-muted);
  }
  .todo {
    color: var(--color-rust);
    letter-spacing: 1px;
  }
</style>
