---
import { Icon } from 'astro-icon/components';
import { projectLinks } from '../lib/projectLinks';
import type { Project } from '../data/content';

const { project } = Astro.props as { project: Project };
const links = projectLinks(project);
---

<article class="card">
  <header class="card-head">
    <Icon name={`tabler:${project.icon}`} class="ic" />
    <span class="title">{project.title}</span>
  </header>
  <div class="card-body">
    <p class="desc">{project.description}</p>
    <div class="tags">
      {project.stack.map((t) => <span class="tag">{t}</span>)}
    </div>
    {links.length > 0 && (
      <div class="links">
        {links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener">
            {l.label}
            <Icon name={`tabler:${l.icon}`} class="lic" />
          </a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--color-border-heavy);
    background: var(--color-bg-surface);
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: var(--color-bg-dark);
  }
  .ic {
    width: 16px;
    height: 16px;
    color: var(--color-rust);
    flex-shrink: 0;
  }
  .title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text-cream);
  }
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px 12px 10px;
    flex: 1;
  }
  .desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    line-height: 1.7;
    color: var(--color-text-body);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .tag {
    padding: 2px 7px;
    background: var(--color-rust);
    color: var(--color-text-cream-dim);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 8px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .links {
    display: flex;
    gap: 14px;
    margin-top: auto;
    padding-top: 4px;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-rust);
  }
  .links a:hover { text-decoration: underline; }
  .lic { width: 11px; height: 11px; }
</style>
