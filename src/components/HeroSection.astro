---
import { hero } from '../data/content';
import { getAssetPresence } from '../lib/assetPresence.server';

const { hasCv } = getAssetPresence();
---

<section class="hero" data-reveal>
  <div class="featured"><span>{hero.featured}</span></div>

  <h2 class="headline">{hero.headline}</h2>
  <p class="body">{hero.body}</p>

  <div class="pills">
    <span class="pill gold">{hero.goldPill}</span>
    {hero.darkPills.map((p) => <span class="pill dark">{p}</span>)}
  </div>

  <div class:list={['cta', { single: !hasCv }]}>
    {hasCv && (
      <a class="btn primary" href={hero.cvPath} download>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"/></svg>
        Download CV
      </a>
    )}
    <a class="btn secondary" href={hero.liveUrl} target="_blank" rel="noopener">
      View SecureExam Live
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
    </a>
  </div>
</section>

<style>
  .hero {
    padding: 20px 24px 16px;
    border-bottom: 3px solid var(--color-border-heavy);
  }

  /* Featured label with rules either side */
  .featured {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .featured::before,
  .featured::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border-mid);
  }
  .featured span {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-rust);
  }

  .headline {
    font-size: 30px;
    color: var(--color-text-primary);
    max-width: 560px;
  }
  .body {
    margin: 12px 0 16px;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 12px;
    line-height: 1.7;
    color: var(--color-text-body);
    max-width: 480px;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }
  .pill {
    padding: 4px 10px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .pill.gold {
    background: var(--color-rust);
    color: var(--color-text-cream-dim);
  }
  .pill.dark {
    background: var(--color-bg-dark);
    color: var(--color-text-cream);
  }

  .cta {
    display: flex;
    gap: 10px;
  }
  .cta.single {
    justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 16px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: 2px solid var(--color-rust);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .btn.primary {
    background: var(--color-rust);
    color: var(--color-text-cream-dim);
  }
  .btn.primary:hover {
    background: var(--color-rust-dark);
    border-color: var(--color-rust-dark);
  }
  .btn.secondary {
    background: transparent;
    color: var(--color-rust);
  }
  .btn.secondary:hover {
    background: var(--color-rust);
    color: var(--color-text-cream-dim);
  }

  @media (max-width: 600px) {
    .headline { font-size: 24px; }
    .cta { flex-direction: column; }
    .cta.single { align-items: center; }
  }
</style>
