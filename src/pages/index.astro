---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import Sidebar from '../components/Sidebar.astro';
import RightRail from '../components/RightRail.astro';
import AboutSection from '../components/AboutSection.astro';
import CredentialsSection from '../components/CredentialsSection.astro';
import WilderfarerSection from '../components/WilderfarerSection.astro';
import ContactSection from '../components/ContactSection.astro';
---

<BaseLayout>
  {/* Content regions are scaffolded empty here; later issues fill them.
      3-column band (#home) — issues 03/04/05 (main), 06 (sidebar), 07 (rail). */}
  <div class="band">
    <aside class="rail-left" aria-label="Profile sidebar">
      <Sidebar />
    </aside>

    <section class="main">
      <HeroSection />
      <ProjectGrid />
      <ExperienceTimeline />
    </section>

    <aside class="rail-right" aria-label="Credentials and personal">
      <RightRail />
    </aside>
  </div>

  {/* Full-width sections below the band */}
  <AboutSection />
  <CredentialsSection />
  <WilderfarerSection />
  <ContactSection />
</BaseLayout>

<style>
  .band {
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr var(--rail-w);
  }
  .rail-left {
    background: var(--color-bg-sidebar);
    border-right: 1px solid var(--color-border-mid);
    min-height: 200px;
  }
  .main {
    min-height: 200px;
  }
  .rail-right {
    background: var(--color-bg-sidebar);
    border-left: 1px solid var(--color-border-mid);
    min-height: 200px;
  }

  /* Responsive collapse is finalized in issue 10; minimal guard here. */
  @media (max-width: 959px) {
    .band { grid-template-columns: 1fr; }
    .rail-left, .rail-right { border: none; min-height: 0; }
  }
</style>
